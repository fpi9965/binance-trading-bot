# ═══════════════════════════════════════════════════════════════════════════════
#                    ملف المتغيرات البيئية - Railway
# ═══════════════════════════════════════════════════════════════════════════════
# انسخ هذا الملف وأعد تسميته إلى .env وأضف قيمك الحقيقية
# أو أضف هذه المتغيرات مباشرة في Railway

# ═══════════════════════════════════════════════════════════════════════════════
#                    إعدادات Binance API
# ═══════════════════════════════════════════════════════════════════════════════

# مفتاح API من Binance
BINANCE_API_KEY=YOUR_BINANCE_API_KEY_HERE

# مفتاح السر من Binance
BINANCE_API_SECRET=YOUR_BINANCE_API_SECRET_HERE

# ═══════════════════════════════════════════════════════════════════════════════
#                    إعدادات Telegram
# ═══════════════════════════════════════════════════════════════════════════════

# Token بوت Telegram
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Chat ID الخاص بك
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

# ═══════════════════════════════════════════════════════════════════════════════
#                    إعدادات التشغيل
# ═══════════════════════════════════════════════════════════════════════════════

# True = وضع الاختبار (لن يتداول الحقيقي)
# False = تداول حقيقي
TEST_MODE=True
